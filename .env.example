# ============================================================================
#  yale-alpha-fund — environment template
#  Copy to `.env` and fill in real values. NEVER commit `.env`.
#  Every variable here is loaded through config/settings.py — nothing reads
#  os.environ directly anywhere else in the codebase (PRINCIPLES.md Rule 4).
# ============================================================================

# ---- FactSet (developer.factset.com — API entitlement, NOT the Workstation) ----
FACTSET_CLIENT_ID=your_factset_client_id
FACTSET_CLIENT_SECRET=your_factset_client_secret

# ---- NVIDIA NIM (NeMo Agent Toolkit signal discovery — build.nvidia.com) ----
NVIDIA_API_KEY=your_nvidia_nim_api_key

# ---- OpenAI (QuantaAlpha + Beyond Prompting) ----
OPENAI_API_KEY=your_openai_api_key

# ---- Anthropic (MadEvolve ensemble) ----
ANTHROPIC_API_KEY=your_anthropic_api_key

# ---- Google (MadEvolve ensemble) ----
GOOGLE_API_KEY=your_google_gemini_api_key

# ---- QuantConnect (backtesting + live trading) ----
QUANTCONNECT_USER_ID=your_qc_user_id
QUANTCONNECT_API_TOKEN=your_qc_api_token

# ---- Interactive Brokers (live execution) ----
IB_ACCOUNT_ID=your_ib_account_id
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1

# ---- Database (signal registry + backtest results) ----
DATABASE_URL=postgresql://localhost:5432/yale_alpha_fund

# ---- Monitoring (optional) ----
SLACK_WEBHOOK_URL=

# ---- SEC EDGAR (free public data; SEC asks for a name + contact email) ----
EDGAR_USER_AGENT=

# ---- Runtime ----
APP_ENV=development          # development | production  (controls log format)
DATA_SOURCE=fixture          # fixture | factset | public  (which DataSource impl to use)
LOG_LEVEL=INFO
